# FenixCRM — Environment Variables Example
# Copy to .env and fill in your values
# cp .env.example .env

# ─── Go Backend ────────────────────────────────────────────────────────────────
# REQUIRED: minimum 32 characters
JWT_SECRET=dev-secret-key-32-chars-minimum!!

# SQLite database path (relative to binary or absolute)
DATABASE_URL=./data/fenixcrm.db

# Server port (default: 8080)
PORT=8080

# ─── Ollama (Local LLM) ────────────────────────────────────────────────────────
# Run locally: ollama serve
# Pull models: ollama pull nomic-embed-text && ollama pull llama3.2:3b-instruct-q4_K_M
OLLAMA_BASE_URL=http://localhost:11434

# Chat model — use exact name from `ollama list`
# Recommended: llama3.2:3b-instruct-q4_K_M (2GB, fast dev), llama3.1:8b-instruct-q4_K_M (better quality)
OLLAMA_CHAT_MODEL=llama3.2:3b-instruct-q4_K_M

# Embedding model — nomic-embed-text produces 768-dimensional vectors
OLLAMA_MODEL=nomic-embed-text

# ─── BFF ───────────────────────────────────────────────────────────────────────
BFF_PORT=3000
BACKEND_URL=http://localhost:8080

# ─── Mobile (Expo) ─────────────────────────────────────────────────────────────
# Leave empty to disable Sentry crash reporting
EXPO_PUBLIC_SENTRY_DSN=

# BFF URL for mobile API calls
EXPO_PUBLIC_BFF_URL=http://localhost:3000
